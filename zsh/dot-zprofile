# Homebrew lives at /opt/homebrew on Apple Silicon and /usr/local on Intel.
# Initialize whichever is present; do nothing if neither exists (e.g. fresh
# checkout before bootstrap has run).
#
# HOMEBREW_NO_ANALYTICS and EDITOR/VISUAL/PATH live in dot-zshenv so they
# apply to non-login shells too.
for brew_bin in /opt/homebrew/bin/brew /usr/local/bin/brew; do
  if [[ -x $brew_bin ]]; then
    eval "$($brew_bin shellenv)"
    break
  fi
done

# Added by OrbStack: command-line tools and integration
# This won't be added again if you remove it.
source ~/.orbstack/shell/init.zsh 2>/dev/null || :

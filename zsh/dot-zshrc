# Zinit (bootstrap + annexes live in their own file). Tracked via a flag so
# the rest of this file (aliases, prompt, keybindings, secrets) still loads
# when Zinit is missing — e.g. in a fresh devcontainer before install.sh has
# run, or with no network on first boot.
if source "$HOME/.config/zsh/zinit-bootstrap.zsh"; then
  zinit light zsh-users/zsh-autosuggestions
  zinit light zsh-users/zsh-syntax-highlighting
  zinit light ajeetdsouza/zoxide
  bindkey '^ ' autosuggest-accept
fi

# Aliases. `command -v` guards so a fresh checkout (or a minimal container
# before its dotfiles install step runs) doesn't fail on every shell start.
alias vim=nvim
command -v lsd >/dev/null && alias ls=lsd

# Fix Title Bar
case $TERM in
  xterm*|*-256color|tmux*|screen*)
    function set-pane-title() { print -Pn "\e]2;%n@%m: %~\a"; }
    precmd_functions+=(set-pane-title)
    ;;
esac

# Export $HISTCMD so starship's [env_var.STARSHIP_CMD_NUM] can display it.
function export-cmd-num() { export STARSHIP_CMD_NUM=$HISTCMD; }
precmd_functions+=(export-cmd-num)

# Default --dotfiles-repository on `devcontainer up` to this repo. Only fires
# when the flag isn't already on the command line, so explicit overrides win.
# No-op when the devcontainer CLI isn't installed (function just defers).
devcontainer() {
  if [[ "${1:-}" == "up" && "$*" != *--dotfiles-repository* ]]; then
    command devcontainer "$@" \
      --dotfiles-repository https://github.com/cdh-src/dotfiles-mbp.git
  else
    command devcontainer "$@"
  fi
}

# Starship Prompt
command -v starship >/dev/null && eval "$(starship init zsh)"

bindkey -v

# PATH, EDITOR, VISUAL, HOMEBREW_NO_ANALYTICS live in dot-zshenv so they
# apply to non-interactive shells too.

# Secrets
[[ -f ~/.zshsecrets ]] && source ~/.zshsecrets

# Packages
zinit light zsh-users/zsh-autosuggestions
zinit light zsh-users/zsh-syntax-highlighting
zinit light ajeetdsouza/zoxide

bindkey '^ ' autosuggest-accept

# Aliases
alias vim=nvim
alias ls=lsd

# Fix Title Bar
case $TERM in
  xterm*|*-256color|tmux*|screen*)
    function set-pane-title() { print -Pn "\e]2;%n@%m: %~\a"; }
    precmd_functions+=(set-pane-title)
    ;;
esac

# Export $HISTCMD so starship's [env_var.STARSHIP_CMD_NUM] can display it.
function export-cmd-num() { export STARSHIP_CMD_NUM=$HISTCMD; }
precmd_functions+=(export-cmd-num)

# Starship Prompt
eval "$(starship init zsh)"

bindkey -v

# For litellm, etc.
export PATH="/Users/chartwig/.local/bin:$PATH"

# Claude Settings
export ANTHROPIC_BASE_URL="http://127.0.0.1:4000"
export ANTHROPIC_DEFAULT_OPUS_MODEL=claude-opus-4.7
export ANTHROPIC_DEFAULT_SONNET_MODEL=claude-sonnet-4.6
export ANTHROPIC_DEFAULT_HAIKU_MODEL=claude-haiku-4.5

export EDITOR=vim

# Secrets
[[ -f ~/.zshsecrets ]] && source ~/.zshsecrets

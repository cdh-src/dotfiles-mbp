#!/usr/bin/env bash
# devc — thin wrapper around `devcontainer` that injects standard mounts and
# the dotfiles repo on every `up`, plus a few convenience subcommands.
#
# Why this exists:
#   - `devcontainer up` takes long, repetitive flag lists for mounts and
#     `--dotfiles-repository`. We always want the same set of host paths
#     (Obsidian vault, Copilot auth, gh config, …) inside every container.
#   - Lets `copilot --allow-all-tools` run inside the container — isolated
#     from host files outside the explicit mounts — so autopilot is safer.
#
# Mounts come from a config file the user can edit:
#   $XDG_CONFIG_HOME/devc/mounts.conf  (default ~/.config/devc/mounts.conf)
# One `--mount` value per line; `#` comments and blank lines ignored;
# `$VAR` and `${VAR}` get expanded against the current environment.
#
# Container user is auto-detected from the devcontainer config (remoteUser,
# falling back to containerUser, falling back to "vscode") and exported as
# $DEVC_CONTAINER_USER + $DEVC_CONTAINER_HOME into the mounts.conf expansion
# environment. Override either by setting them before `devc up`.
#
# Dotfiles repo: $DEVC_DOTFILES_REPO, defaults to this repo.
#
# Workspace folder: auto-discovered by walking up from $PWD looking for
# `.devcontainer/devcontainer.json` or `.devcontainer.json`. Override with
# `--workspace-folder PATH` (must precede the subcommand, or use `devc <cmd>
# --workspace-folder PATH`).

set -euo pipefail

# ---- defaults -------------------------------------------------------------

DEVC_DOTFILES_REPO="${DEVC_DOTFILES_REPO:-https://github.com/cdh-src/dotfiles-mbp.git}"
DEVC_MOUNTS_FILE="${DEVC_MOUNTS_FILE:-${XDG_CONFIG_HOME:-$HOME/.config}/devc/mounts.conf}"

# ---- helpers --------------------------------------------------------------

err() { printf 'devc: %s\n' "$*" >&2; }
die() { err "$*"; exit 1; }

usage() {
  cat <<'USAGE'
Usage: devc [--workspace-folder PATH] <command> [args...]

Container lifecycle:
  up           Start (or recreate if config changed) the devcontainer with
               standard mounts and the dotfiles repo injected.
  rebuild      Force a clean rebuild (--remove-existing-container).
  down         Stop the container (resolves id via `devcontainer
               read-configuration` + `docker stop`).

Entering:
  shell        Open an interactive login shell inside the container.
  exec ARGS... Run one-off command inside the container.

Copilot:
  copilot ARGS Run `copilot --allow-all-tools ARGS` inside the container.

Introspection:
  status       Show running state, container id, image, mounts.
  logs         Tail container logs.
  config       Print resolved devcontainer config.

Other:
  help, -h, --help     Show this help.

Workspace folder is auto-discovered by walking up from $PWD for a
.devcontainer/ directory. Override with --workspace-folder PATH.

Standard mounts are read from:
  $DEVC_MOUNTS_FILE
USAGE
}

# Walk up from $PWD to find the nearest ancestor containing a devcontainer
# config. Echoes the path on success; exits non-zero with a clear error on
# failure.
find_workspace_folder() {
  local dir
  dir="$(pwd -P)"
  while :; do
    if [[ -f "$dir/.devcontainer/devcontainer.json" \
       || -f "$dir/.devcontainer.json" ]]; then
      printf '%s\n' "$dir"
      return 0
    fi
    [[ "$dir" == "/" ]] && return 1
    dir="$(dirname "$dir")"
  done
}

# Resolve the container user for a workspace, in priority order:
#   1. $DEVC_CONTAINER_USER (explicit override).
#   2. mergedConfiguration.remoteUser from `devcontainer read-configuration`.
#   3. mergedConfiguration.containerUser.
#   4. configuration.remoteUser / configuration.containerUser (single-config
#      fallback for older CLI output shapes).
#   5. "vscode" (devcontainer default).
# Echoes the resolved username on stdout. Never fails — there is always a
# fallback. Logs to stderr which source won.
resolve_container_user() {
  local wsf="$1"
  if [[ -n "${DEVC_CONTAINER_USER:-}" ]]; then
    err "container user: $DEVC_CONTAINER_USER (from \$DEVC_CONTAINER_USER)"
    printf '%s\n' "$DEVC_CONTAINER_USER"
    return 0
  fi
  local resolved source
  read -r resolved source < <(
    devcontainer read-configuration \
      --workspace-folder "$wsf" \
      --include-merged-configuration 2>/dev/null \
    | python3 -c '
import json, sys
try:
    d = json.load(sys.stdin)
except Exception:
    sys.exit(0)
for root_key, label in (("mergedConfiguration", "merged"), ("configuration", "config")):
    root = d.get(root_key) or {}
    for field in ("remoteUser", "containerUser"):
        v = root.get(field)
        if v:
            print(f"{v} {label}.{field}")
            sys.exit(0)
' || true
  )
  if [[ -n "$resolved" ]]; then
    err "container user: $resolved (from devcontainer config: $source)"
    printf '%s\n' "$resolved"
    return 0
  fi
  err "container user: vscode (fallback — no remoteUser/containerUser found)"
  printf '%s\n' "vscode"
}

# Derive the container-side home directory from a username. Honors
# $DEVC_CONTAINER_HOME override; otherwise "root" → /root, anything else →
# /home/$user. (Matches the conventional layout used by every devcontainer
# base image we've encountered.)
resolve_container_home() {
  local user="$1"
  if [[ -n "${DEVC_CONTAINER_HOME:-}" ]]; then
    printf '%s\n' "$DEVC_CONTAINER_HOME"
    return 0
  fi
  if [[ "$user" == "root" ]]; then
    printf '%s\n' "/root"
  else
    printf '%s\n' "/home/$user"
  fi
}

# Read $DEVC_MOUNTS_FILE and echo one expanded line per active mount entry.
# Blank lines and lines starting with `#` are ignored. Each line is passed
# through `envsubst`-equivalent expansion via the shell so $HOME, $USER,
# $DEVC_CONTAINER_USER, $DEVC_CONTAINER_HOME, etc. resolve.
read_mounts() {
  [[ -f "$DEVC_MOUNTS_FILE" ]] || return 0
  local line
  while IFS= read -r line || [[ -n "$line" ]]; do
    # strip leading/trailing whitespace
    line="${line#"${line%%[![:space:]]*}"}"
    line="${line%"${line##*[![:space:]]}"}"
    [[ -z "$line" || "$line" == \#* ]] && continue
    # eval with `printf '%s'` to expand env vars but nothing else dangerous.
    # We deliberately use eval here; the file is user-owned config.
    eval "printf '%s\n' \"$line\""
  done < "$DEVC_MOUNTS_FILE"
}

# Build the array of `--mount VAL` args from the mounts config.
mount_args() {
  local m
  while IFS= read -r m; do
    [[ -z "$m" ]] && continue
    printf -- '--mount\n%s\n' "$m"
  done < <(read_mounts)
}

# Resolve the running container id for a workspace, if any. Prints id on
# success, empty string + nonzero return otherwise.
resolve_container_id() {
  local wsf="$1"
  devcontainer read-configuration --workspace-folder "$wsf" \
    --include-merged-configuration 2>/dev/null \
    | python3 -c '
import json, sys
try:
    d = json.load(sys.stdin)
except Exception:
    sys.exit(1)
cid = (d.get("containerId") or d.get("container", {}).get("id") or "")
if not cid:
    sys.exit(1)
print(cid)
' || return 1
}

# Resolve container id via `docker ps` filter as a fallback (matches the
# devcontainer label for this workspace).
resolve_container_id_docker() {
  local wsf="$1"
  docker ps -q --filter "label=devcontainer.local_folder=$wsf" 2>/dev/null | head -n1
}

# ---- arg parsing ----------------------------------------------------------

WORKSPACE_FOLDER=""
# Pull --workspace-folder from anywhere in args (before or after subcommand).
positional=()
while (( $# > 0 )); do
  case "$1" in
    --workspace-folder)
      [[ $# -ge 2 ]] || die "--workspace-folder needs a value"
      WORKSPACE_FOLDER="$2"; shift 2
      ;;
    --workspace-folder=*)
      WORKSPACE_FOLDER="${1#*=}"; shift
      ;;
    -h|--help|help)
      usage; exit 0
      ;;
    *)
      positional+=("$1"); shift
      ;;
  esac
done

set -- "${positional[@]:+${positional[@]}}"
(( $# > 0 )) || { usage >&2; exit 2; }

cmd="$1"; shift

# Validate subcommand name BEFORE resolving the workspace folder so a typo
# shows "unknown subcommand" instead of "no .devcontainer/ found".
case "$cmd" in
  up|rebuild|down|shell|exec|copilot|status|logs|config) ;;
  *)
    err "unknown subcommand: $cmd"
    usage >&2
    exit 2
    ;;
esac

# Resolve workspace folder for commands that need one (everything except
# help; even `status` needs to know which project).
if [[ -z "$WORKSPACE_FOLDER" ]]; then
  if ! WORKSPACE_FOLDER="$(find_workspace_folder)"; then
    die "no .devcontainer/ found at or above $(pwd -P). Pass --workspace-folder PATH or cd into a project."
  fi
fi

command -v devcontainer >/dev/null 2>&1 \
  || die "'devcontainer' CLI not found. Install with: npm install -g @devcontainers/cli"

# ---- subcommands ----------------------------------------------------------

case "$cmd" in
  up|rebuild)
    extra=()
    [[ "$cmd" == "rebuild" ]] && extra+=(--remove-existing-container)
    # Resolve container user + home BEFORE expanding mounts.conf so the file
    # can reference ${DEVC_CONTAINER_HOME}.
    DEVC_CONTAINER_USER="$(resolve_container_user "$WORKSPACE_FOLDER")"
    DEVC_CONTAINER_HOME="$(resolve_container_home "$DEVC_CONTAINER_USER")"
    export DEVC_CONTAINER_USER DEVC_CONTAINER_HOME
    # Build mount args. Read into an array so spaces in values survive.
    mounts=()
    while IFS= read -r m; do
      [[ -n "$m" ]] && mounts+=(--mount "$m")
    done < <(read_mounts)
    if (( ${#mounts[@]} == 0 )) && [[ ! -f "$DEVC_MOUNTS_FILE" ]]; then
      err "warning: mounts file $DEVC_MOUNTS_FILE not found; bringing container up with no extra mounts."
    fi
    exec devcontainer up \
      --workspace-folder "$WORKSPACE_FOLDER" \
      ${mounts[@]+"${mounts[@]}"} \
      --dotfiles-repository "$DEVC_DOTFILES_REPO" \
      ${extra[@]+"${extra[@]}"} \
      "$@"
    ;;

  down)
    cid="$(resolve_container_id "$WORKSPACE_FOLDER" 2>/dev/null || true)"
    [[ -z "$cid" ]] && cid="$(resolve_container_id_docker "$WORKSPACE_FOLDER" || true)"
    [[ -z "$cid" ]] && die "no running container found for $WORKSPACE_FOLDER"
    exec docker stop "$cid"
    ;;

  shell)
    sh="${SHELL:-/bin/bash}"
    exec devcontainer exec --workspace-folder "$WORKSPACE_FOLDER" \
      --remote-env OBSIDIAN_VAULT=/obsidian \
      "$sh" -l "$@"
    ;;

  exec)
    (( $# > 0 )) || die "exec needs a command"
    exec devcontainer exec --workspace-folder "$WORKSPACE_FOLDER" \
      --remote-env OBSIDIAN_VAULT=/obsidian \
      "$@"
    ;;

  copilot)
    exec devcontainer exec --workspace-folder "$WORKSPACE_FOLDER" \
      --remote-env OBSIDIAN_VAULT=/obsidian \
      copilot --allow-all-tools "$@"
    ;;

  status)
    cid="$(resolve_container_id "$WORKSPACE_FOLDER" 2>/dev/null || true)"
    [[ -z "$cid" ]] && cid="$(resolve_container_id_docker "$WORKSPACE_FOLDER" || true)"
    if [[ -z "$cid" ]]; then
      printf 'workspace: %s\nstate:     not running\n' "$WORKSPACE_FOLDER"
      exit 0
    fi
    printf 'workspace: %s\ncontainer: %s\nstate:     running\n\n' "$WORKSPACE_FOLDER" "$cid"
    docker inspect --format \
      'image:     {{.Config.Image}}
started:   {{.State.StartedAt}}
mounts:' "$cid"
    docker inspect --format \
      '{{range .Mounts}}  - {{.Type}} {{.Source}} → {{.Destination}}{{if .RW}}{{else}} (ro){{end}}
{{end}}' "$cid"
    ;;

  logs)
    cid="$(resolve_container_id "$WORKSPACE_FOLDER" 2>/dev/null || true)"
    [[ -z "$cid" ]] && cid="$(resolve_container_id_docker "$WORKSPACE_FOLDER" || true)"
    [[ -z "$cid" ]] && die "no container found for $WORKSPACE_FOLDER"
    exec docker logs -f "$cid" "$@"
    ;;

  config)
    exec devcontainer read-configuration \
      --workspace-folder "$WORKSPACE_FOLDER" \
      --include-merged-configuration "$@"
    ;;
esac
